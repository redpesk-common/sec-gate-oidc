<?xml version="1.0" encoding="UTF-8"?>
<widget xmlns="http://www.w3.org/ns/widgets" id="@PROJECT_NAME@" version="@PROJECT_VERSION@">
  <name>@PROJECT_NAME@</name>
  <icon src="icon.jpg"/>
  <content src="lib/libafb-sec-gate-oidc-ext.so" type="application/vnd.agl.service"/>
  <description>@PROJECT_DESCRIPTION@</description>
  <author>IoT.bzh</author>
  <license>APL2.0</license>

  <feature name="urn:AGL:widget:provided-api">
    <param name="sec-gate-oidc" value="ws" />
  </feature>

  <feature name="urn:AGL:widget:required-permission">
    <param name="urn:AGL:permission::public:hidden" value="required" />
  </feature>

  <feature name="urn:AGL:widget:required-binding">
     <param name="lib/libafb-sec-gate-oidc-ext.so" value="local" />
  </feature>
</widget>
